{
  "name": "noobly-core",
  "version": "1.1.0",
  "description": "A powerful set of modular Node.js backend services with singleton pattern - caching, logging, data serving, filing, measuring, notifying, queueing, scheduling, searching, workflow, and working services.",
  "keywords": [
    "nodejs",
    "backend",
    "services",
    "microservices",
    "cache",
    "logging",
    "queue",
    "workflow",
    "express"
  ],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=12.11.0"
  },
  "scripts": {
    "clean": "rimraf dist/*; rimraf jsdocs/*;",
    "dev": "npm run clean; nodemon --watch ./src ./app.js",
    "test": "jest",
    "test-load": "node ./tests-load/",
    "build": "jsdoc -c jsdoc.json; npm version minor; babel src -d dist; npm pack --pack-destination='package'"
  },
  "jest": {
    "modulePaths": [
      "./"
    ],
    "transform": {},
    "forceExit": true,
    "detectOpenHandles": true
  },
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "gts": "^6.0.2",
    "jest": "^30.0.3",
    "jsdoc": "^4.0.4"
  },
  "dependencies": {
    "aws-sdk": "^2.1620.0",
    "body-parser": "^1.20.2",
    "express": "^4.19.2",
    "ftp": "^0.3.10",
    "ioredis": "^5.6.1",
    "ioredis-mock": "^8.9.0",
    "memjs": "^1.3.0",
    "nodemon": "^3.1.10",
    "redis": "^5.5.6",
    "rimraf": "^6.0.1",
    "uuid": "^11.1.0"
  }
}
